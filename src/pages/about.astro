---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About">
	<Navbar />
	<main class="about">
		<section class="about-hero">
			<div class="container">
				<h1 class="page-title">About Me</h1>
				<p class="page-subtitle">Backend developer passionate about clean code and solid architectures</p>
			</div>
		</section>

		<section class="about-content">
			<div class="container">
				<div class="about-grid">
					<div class="about-text">
						<h2>My Journey</h2>
						<p>
							Backend developer with several years of experience, I specialize in creating
							robust APIs and scalable systems. My passion for clean code and best practices
							drives me to constantly improve my skills.
						</p>
						<p>
							I enjoy tackling complex technical challenges and transforming problems into
							elegant solutions. My approach combines technical rigor with the creativity
							needed to innovate.
						</p>

						<h2>My Philosophy</h2>
						<ul class="philosophy-list">
							<li>
								<svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="20 6 9 17 4 12"></polyline>
								</svg>
								<span>Code should be readable and maintainable</span>
							</li>
							<li>
								<svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="20 6 9 17 4 12"></polyline>
								</svg>
								<span>Simplicity over complexity</span>
							</li>
							<li>
								<svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="20 6 9 17 4 12"></polyline>
								</svg>
								<span>Tests are essential for quality</span>
							</li>
							<li>
								<svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="20 6 9 17 4 12"></polyline>
								</svg>
								<span>Continuous learning is indispensable</span>
							</li>
						</ul>
					</div>

					<div class="about-sidebar">
						<div class="info-card">
							<h3>Information</h3>
							<div class="info-item">
								<span class="label">Name</span>
								<span class="value">Noam Roger</span>
							</div>
							<div class="info-item">
								<span class="label">Location</span>
								<span class="value">Le Mans (France)</span>
							</div>
							<div class="info-item">
								<span class="label">Availability</span>
								<span class="value">Open to opportunities</span>
							</div>
						</div>

						<div class="tech-card">
							<h3>Tech Stack</h3>
							<div class="tech-list">
								<span class="tech-tag">Node.js</span>
								<span class="tech-tag">TypeScript</span>
								<span class="tech-tag">C</span>
								<span class="tech-tag">Java</span>
								<span class="tech-tag">PHP</span>
								<span class="tech-tag">Python</span>
								<span class="tech-tag">PostgreSQL</span>
								<span class="tech-tag">MariaDB</span>
								<span class="tech-tag">MySQL</span>
								<span class="tech-tag">Docker</span>
								<span class="tech-tag">React</span>
								<span class="tech-tag">Astro</span>
								<span class="tech-tag">Cloudflare</span>
								<span class="tech-tag">Git</span>
								<span class="tech-tag">Proxmox</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.about {
		flex: 1;
	}

	.about-hero {
		padding: 4rem 0;
		background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
		text-align: center;
	}

	.page-title {
		font-size: 3rem;
		font-weight: 800;
		margin-bottom: 1rem;
		opacity: 0;
		animation: fadeInUp 0.8s ease forwards;
	}

	.page-subtitle {
		font-size: 1.25rem;
		color: var(--text-secondary);
		max-width: 600px;
		margin: 0 auto;
		opacity: 0;
		animation: fadeInUp 0.8s ease 0.2s forwards;
	}

	.about-content {
		padding: 4rem 0;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 4rem;
	}

	.about-text h2 {
		font-size: 1.75rem;
		margin-bottom: 1rem;
		margin-top: 2rem;
		opacity: 0;
		animation: fadeInUp 0.8s ease forwards;
	}

	.about-text h2:nth-of-type(1) { animation-delay: 0.3s; }
	.about-text h2:nth-of-type(2) { animation-delay: 0.5s; }

	.about-text p {
		color: var(--text-secondary);
		line-height: 1.8;
		margin-bottom: 1rem;
		opacity: 0;
		animation: fadeInUp 0.8s ease forwards;
	}

	.about-text p:nth-of-type(1) { animation-delay: 0.4s; }
	.about-text p:nth-of-type(2) { animation-delay: 0.6s; }

	.philosophy-list {
		list-style: none;
		margin-top: 1rem;
	}

	.philosophy-list li {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 0.75rem 0;
		color: var(--text-secondary);
		opacity: 0;
		animation: fadeInUp 0.8s ease forwards;
	}

	.philosophy-list li:nth-child(1) { animation-delay: 0.7s; }
	.philosophy-list li:nth-child(2) { animation-delay: 0.8s; }
	.philosophy-list li:nth-child(3) { animation-delay: 0.9s; }
	.philosophy-list li:nth-child(4) { animation-delay: 1s; }

	.check-icon {
		width: 20px;
		height: 20px;
		color: var(--accent-blue);
		flex-shrink: 0;
		transition: transform 0.3s ease;
	}

	.philosophy-list li:hover .check-icon {
		transform: scale(1.2);
	}

	.info-card,
	.tech-card {
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		padding: 2rem;
		margin-bottom: 2rem;
		opacity: 0;
		transform: translateY(30px);
		animation: fadeInUp 0.8s ease forwards;
	}

	.info-card { animation-delay: 0.5s; }
	.tech-card { animation-delay: 0.7s; }

	@keyframes fadeInUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.info-card h3,
	.tech-card h3 {
		font-size: 1.25rem;
		margin-bottom: 1.5rem;
	}

	.info-item {
		display: flex;
		justify-content: space-between;
		padding: 0.75rem 0;
		border-bottom: 1px solid var(--border-color);
	}

	.info-item:last-child {
		border-bottom: none;
	}

	.info-item .label {
		color: var(--text-muted);
	}

	.info-item .value {
		color: var(--text-primary);
		font-weight: 500;
	}

	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tech-tag {
		background: var(--bg-tertiary);
		color: var(--accent-blue);
		padding: 0.375rem 0.75rem;
		border-radius: 16px;
		font-size: 0.75rem;
		font-weight: 500;
		border: 1px solid var(--border-color);
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
	}

	.tech-tag::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.2), transparent);
		transition: left 0.5s ease;
	}

	.tech-tag:hover::before {
		left: 100%;
	}

	.tech-tag:hover {
		border-color: var(--accent-blue);
		background: linear-gradient(135deg, var(--bg-tertiary), rgba(59, 130, 246, 0.1));
	}

	@media (max-width: 1024px) {
		.about-grid {
			grid-template-columns: 1fr;
		}

		.about-sidebar {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}
	}

	@media (max-width: 768px) {
		.page-title {
			font-size: 2rem;
		}

		.about-sidebar {
			grid-template-columns: 1fr;
		}

		.about-content {
			padding: 2rem 0;
		}
	}
</style>
