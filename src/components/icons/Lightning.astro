---
interface Props {
	class?: string;
	width?: string | number;
	height?: string | number;
}

const { class: className = '', width = 24, height = 24 } = Astro.props;
---

<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} width={width} height={height}>
	<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
</svg>
